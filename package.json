{
  "name": "@its-not-rocket-science/ananke-world-ui",
  "version": "0.2.0",
  "type": "module",
  "description": "Standalone world creation and simulation UI for @its-not-rocket-science/ananke",
  "license": "MIT",
  "scripts": {
    "dev": "vite dev",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "typecheck": "svelte-kit sync && tsc --noEmit",
    "build": "svelte-kit sync && vite build",
    "preview": "vite preview"
  },
  "dependencies": {
    "@its-not-rocket-science/ananke": "^0.1.4",
    "svelte": "^5.0.0"
  },
  "optionalDependencies": {
    "ananke-threejs-bridge": "^0.1.0"
  },
  "devDependencies": {
    "@sveltejs/adapter-auto": "^3.0.0",
    "@sveltejs/kit": "^2.0.0",
    "@sveltejs/vite-plugin-svelte": "^5.0.0",
    "svelte-check": "^4.0.0",
    "typescript": "^5.5.4",
    "vite": "^6.0.0"
  }
}
