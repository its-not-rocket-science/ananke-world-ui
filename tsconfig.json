{
  "extends": "./.svelte-kit/tsconfig.json",
  "compilerOptions": {
    "allowJs": true,
    "checkJs": false,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "moduleResolution": "bundler",
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    "skipLibCheck": true,
    "strict": true,
    "paths": {
      "@its-not-rocket-science/ananke/polity": [
        "./node_modules/@its-not-rocket-science/ananke/dist/src/polity.d.ts"
      ],
      "@its-not-rocket-science/ananke/dist/src/polity.js": [
        "./node_modules/@its-not-rocket-science/ananke/dist/src/polity.d.ts"
      ]
    }
  },
  "include": [
    "src/**/*.d.ts",
    "src/**/*.ts",
    "src/**/*.js",
    "src/**/*.svelte",
    "vite.config.ts",
    "svelte.config.js"
  ]
}
